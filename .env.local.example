# Required frontend runtime for local operator auth and session resolution
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required for the local /api/eot/* proxy path
# This must exactly match backend/.env EOT_INTERNAL_AUTH_SECRET.
EOT_INTERNAL_AUTH_SECRET=replace-with-the-same-local-shared-secret
EOT_API_BASE_URL=http://127.0.0.1:8000

# Optional local overrides
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_OPERATOR_OUTBOUND_WEBHOOK_URL=
NEXT_PUBLIC_DASHBOARD_SIGN_IN_URL=http://localhost:3000/login

# Optional tenant bootstrap fallback for local auth bootstrap scripts
EOT_TENANT_ID=
NEXT_PUBLIC_EOT_TENANT_ID=
