# Required backend runtime
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/renovo
APP_ENV=local
DEBUG=true
PROJECT_NAME=Renovo Backend
API_V1_PREFIX=/api/v1

# Required for /api/eot/* trusted operator auth.
# This must exactly match EOT_INTERNAL_AUTH_SECRET in the frontend .env.local file.
EOT_INTERNAL_AUTH_SECRET=replace-with-the-same-local-shared-secret

# Optional backend integrations.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_INSPECTIONS=inspection-files
