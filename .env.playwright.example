# Playwright runner env only. The Next.js app still reads .env.local.
# Leave this at localhost for local smoke runs, or point it at a preview URL to skip the local webServer.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Test account — must exist in Supabase. The dashboard UI is Microsoft SSO
# only and email/password auth is disabled at the Supabase project level, so
# tests/smoke/auth.setup.ts mints a session via the Supabase admin API
# (generate_link + verify) using the service role key.
PLAYWRIGHT_ADMIN_EMAIL=operator@example.com

# Supabase credentials. URL + anon key copy from .env.local (anon key is
# public-safe). The service role key is a SECRET — never commit this value
# and only mirror it into CI via a protected secret.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
